# Groq — required for every Llama call. Free-tier keys at https://console.groq.com/
GROQ_API_KEY=gsk_...

# libsql / Turso — single SQLite file locally, optional Turso Cloud for prod.
# `file:./data/helm.db` is the dev default; ./data/helm.db is gitignored.
# Swap to `libsql://<name>.turso.io` + LIBSQL_AUTH_TOKEN to point at Turso Cloud.
LIBSQL_URL=file:./data/helm.db
# LIBSQL_AUTH_TOKEN=  # required only when LIBSQL_URL targets Turso Cloud

# Backend
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Frontend
VITE_API_URL=http://localhost:3001

# MCP servers — stdio in dev, SSE URLs in prod
MCP_ERP_URL=
MCP_CRM_URL=
MCP_AP_URL=
MCP_CHANNEL_URL=

# Optional — only set when running the demo recording suite
DEMO=0
DEMO_SLOWMO=1200
DEMO_TYPE_DELAY=70
DEMO_TAIL_MS=1500
DEMO_DWELL_MS=1500
DEMO_ZOOM=1.3
