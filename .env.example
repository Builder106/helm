# Gemini Flash — Helm's default vision extractor. Free key at
# https://aistudio.google.com/app/apikey (Google AI Studio).
#
# Default model: gemini-3.1-flash-lite (override via GEMINI_MODEL).
# Lite-tier free quota is ~15 RPM and ~1000 RPD; image input is
# flat-rated per tile (~258 tokens per typical invoice PNG), so a
# full 200-invoice run completes in ~14 minutes at zero cost.
#
# Helm has cycled through five model commits in a week — the
# env-overridable design is what keeps each reshuffle a one-line
# change. Set GEMINI_MODEL=gemini-3.1-pro for deeper reasoning on
# the KPI Q&A path (smaller free-tier RPD).
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.1-flash-lite
# GEMINI_MIN_INTERVAL_MS=4000   # bump higher for non-Lite Flash variants

# Groq — alternative vision provider (Llama 4 Scout). Kept in the repo
# as a secondary extractor; the Extractor interface is provider-
# agnostic by design. Free-tier daily token cap (500K TPD) blocks the
# full 200-invoice corpus, so Groq is footnoted, not default. Free
# keys at https://console.groq.com/
# GROQ_API_KEY=gsk_...

# libsql / Turso — single SQLite file locally, optional Turso Cloud for prod.
# `file:./data/helm.db` is the dev default; ./data/helm.db is gitignored.
# Swap to `libsql://<name>.turso.io` + LIBSQL_AUTH_TOKEN to point at Turso Cloud.
LIBSQL_URL=file:./data/helm.db
# LIBSQL_AUTH_TOKEN=  # required only when LIBSQL_URL targets Turso Cloud

# Backend
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Frontend
VITE_API_URL=http://localhost:3001

# MCP servers — stdio in dev, SSE URLs in prod
MCP_ERP_URL=
MCP_CRM_URL=
MCP_AP_URL=
MCP_CHANNEL_URL=