# Anthropic — required for every Claude call
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — Postgres + pgvector backing the KB retrieval and KPI Q&A
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Backend
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Frontend
VITE_API_URL=http://localhost:3001

# MCP servers — stdio in dev, SSE URLs in prod
MCP_ERP_URL=
MCP_CRM_URL=
MCP_AP_URL=
MCP_CHANNEL_URL=

# Optional — only set when running the demo recording suite
DEMO=0
DEMO_SLOWMO=1200
DEMO_TYPE_DELAY=70
DEMO_TAIL_MS=1500
DEMO_DWELL_MS=1500
DEMO_ZOOM=1.3
