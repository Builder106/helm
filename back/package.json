{
  "name": "@helm/back",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tailwindcss -i src/index.css -o public/styles.css --watch\" \"tsx watch src/server.ts\"",
    "build:css": "tailwindcss -i src/index.css -o public/styles.css",
    "build": "pnpm run build:css && tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@fastify/static": "^10.1.0",
    "@fastify/view": "^12.0.0",
    "ejs": "^6.0.1",
    "fastify": "^5.10.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "@types/node": "^26.1.1",
    "autoprefixer": "^10.5.4",
    "concurrently": "^10.0.3",
    "postcss": "^8.5.20",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
