<% const h = payoutReport.headline; %>

<div class="flex flex-col gap-10" id="trial-02">
  <div class="rise flex flex-col gap-5" style="animation-delay: 20ms;">
    <div class="flex items-center gap-3">
      <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-helm-brass">trial 02</span>
      <span class="h-px w-10 bg-helm-brass/60"></span>
      <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-helm-vellum-faint">
        sub-trial · 2 of 4
      </span>
    </div>

    <div class="flex items-baseline gap-4 flex-wrap">
      <h1
        class="text-[52px] font-bold leading-[0.95] tracking-tight text-helm-vellum"
        style="font-family: var(--font-display); letter-spacing: -0.035em;"
      >
        Creator Payout
      </h1>
      <span
        class="font-mono text-[36px] font-bold leading-none text-helm-cyan"
        style="letter-spacing: -0.02em;"
      >
        RECONCILER
      </span>
    </div>

    <p class="max-w-3xl text-[15px] leading-relaxed text-helm-vellum-muted">
      Each creator's monthly orders are paired with a natural-language payout policy
      (commission tiers, refund rules, currency FX, minimum-payout threshold) and sent to
      Gemini as a single system prompt. The model emits a structured payout breakdown,
      which is scored field-by-field against a deterministic ground-truth computer that
      mirrors the same policy in code.
    </p>

    <div class="flex flex-wrap items-center gap-x-3 gap-y-2 border-y border-helm-cyan/15 py-3">
      <% 
        const cells = [
          { label: 'model',     value: 'gemini-3.1-flash-lite' },
          { label: 'provider',  value: 'google ai studio' },
          { label: 'fixture',   value: '50 creators · 863 orders' },
          { label: 'seed',      value: payoutReport.seed },
          { label: 'extractor', value: payoutReport.extractor },
        ];
      %>
      <% cells.forEach((c, i) => { %>
        <span class="inline-flex items-center gap-1.5 font-mono text-[11px]">
          <span class="uppercase tracking-[0.16em] text-helm-cyan-dim"><%= c.label %></span>
          <span class="tabular text-helm-vellum"><%= c.value %></span>
          <% if (i < cells.length - 1) { %>
            <span class="ml-2 text-helm-brass">▸</span>
          <% } %>
        </span>
      <% }) %>
    </div>

    <% if (isPayoutMock) { %>
      <div class="mt-2 flex items-start gap-4 border border-helm-warn/40 bg-helm-warn/[0.06] px-5 py-4 backdrop-blur">
        <span aria-hidden class="mt-1.5 size-2 shrink-0 rounded-full bg-helm-warn"></span>
        <div>
          <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-helm-warn">
            mock reconciler
          </div>
          <div class="mt-1.5 max-w-3xl text-[13.5px] leading-relaxed text-helm-vellum-muted">
            Field accuracy and per-creator drift below come from a controlled-noise mock of
            the policy-reasoning call, not real API output. Run{' '}
            <code class="border border-helm-cyan/20 bg-helm-twilight/60 px-1.5 py-0.5 font-mono text-[11.5px] text-helm-vellum">
              pnpm measure:payout-reconciler --seed 1 --extractor gemini
            </code>{' '}
            for measured numbers.
          </div>
        </div>
      </div>
    <% } %>
  </div>

  <section class="rise grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-4" style="animation-delay: 120ms;">
    <%- include('MetricCard', {
      index: "01",
      label: "exact match",
      value: formatPercent(h.exact_match_rate),
      sublabel: `<span class="tabular font-mono text-helm-vellum">${h.exact_match_count}</span> of <span class="tabular font-mono text-helm-vellum">${h.creators_processed}</span> creators perfectly matched the deterministic ground truth.`,
      hint: null,
      tone: h.exact_match_rate >= 0.85 ? 'good' : 'warn'
    }) %>
    <%- include('MetricCard', {
      index: "02",
      label: "field accuracy",
      value: formatPercent(h.extraction.field_accuracy),
      sublabel: "14 fields per creator (totals, base, rate, commission, USD payout, status). Cent-level tolerance on monetary fields.",
      hint: null,
      tone: h.extraction.field_accuracy >= 0.95 ? 'good' : 'warn'
    }) %>
    <%- include('MetricCard', {
      index: "03",
      label: "cost / creator",
      value: formatUsd(h.cost.mean_per_creator_usd),
      sublabel: `<span class="tabular font-mono text-helm-vellum">${formatUsd(h.cost.total_usd)}</span> total across the run.`,
      hint: null,
      tone: "neutral"
    }) %>
    <%- include('MetricCard', {
      index: "04",
      label: "labor recovered",
      value: `${h.labor.time_reduction_ratio}×`,
      sublabel: `<span class="tabular font-mono text-helm-vellum">${h.labor.minutes_saved}</span> minutes saved at $25/hr loaded wage.`,
      hint: `≈ ${formatUsd(h.labor.dollars_saved)} this batch`,
      tone: "good"
    }) %>
  </section>

  <section class="rise grid grid-cols-1 gap-5 xl:grid-cols-[1.35fr_1fr]" style="animation-delay: 220ms;">
    <% 
      const discrepancies = payoutReport.records
        .filter((r) => !r.exact_match)
        .sort((a, b) => b.payout_drift_usd - a.payout_drift_usd);
    %>
    <div
      class="relative flex flex-col border border-helm-cyan/15 backdrop-blur-md"
      style="background: linear-gradient(180deg, rgba(125, 211, 224, 0.05) 0%, rgba(8, 42, 69, 0.55) 30%, rgba(4, 27, 50, 0.55) 100%);"
    >
      <span aria-hidden class="pointer-events-none absolute right-0 top-0 size-2.5 border-r border-t border-helm-brass/70"></span>
      <span aria-hidden class="pointer-events-none absolute bottom-0 left-0 size-2.5 border-b border-l border-helm-brass/70"></span>

      <div class="border-b border-helm-cyan/15 px-7 py-5">
        <div class="eyebrow">discrepancies · per creator</div>
        <h3
          class="mt-2 text-[22px] font-bold leading-tight tracking-tight text-helm-vellum"
          style="font-family: var(--font-display); letter-spacing: -0.02em;"
        >
          Creators flagged for <span class="text-helm-cyan">human review</span>
        </h3>
        <p class="mt-1 max-w-md text-[12.5px] leading-snug text-helm-vellum-muted">
          <%= discrepancies.length %> of <%= payoutReport.headline.creators_processed %> creators
          diverged from the deterministic ground truth. Showing largest dollar drift first.
        </p>
      </div>

      <% if (discrepancies.length === 0) { %>
        <div class="px-7 py-10 text-center font-mono text-[12px] text-helm-vellum-faint">
          No discrepancies — all <%= payoutReport.headline.creators_processed %> creators exact-match.
        </div>
      <% } else { %>
        <ol class="max-h-[400px] overflow-y-auto divide-y divide-helm-cyan/[0.07]">
          <% discrepancies.slice(0, 20).forEach((r) => { %>
            <li class="flex items-baseline gap-2 px-7 py-2 font-mono text-[12px] leading-snug hover:bg-helm-cyan/[0.05]">
              <span class="tabular text-helm-vellum"><%= r.creator_id %></span>
              <span class="text-helm-cyan-dim">·</span>
              <span class="text-helm-vellum-muted"><%= r.handle %></span>
              <span class="text-helm-brass">▸</span>
              <span class="tabular text-helm-vellum-muted">
                truth:<span class="text-helm-vellum"><%= formatUsd(r.truth_payout_usd) %></span>{' '}
                pred:<span class="text-helm-vellum"><%= formatUsd(r.predicted_payout_usd) %></span>{' '}
                drift:
                <span class="<%= r.payout_drift_usd > 1 ? 'text-helm-warn' : 'text-helm-vellum' %>">
                  <%= formatUsd(r.payout_drift_usd) %>
                </span>{' '}
                field-acc:<span class="text-helm-vellum"><%= formatPercent(r.field_accuracy) %></span>
              </span>
              <span class="text-helm-brass">▸</span>
              <span
                class="tabular uppercase tracking-[0.08em] <%= r.status_correct ? 'text-helm-pass' : 'text-helm-fail' %>"
              >
                status:<%= r.status_correct ? 'ok' : 'flip' %>
              </span>
            </li>
          <% }) %>
        </ol>
      <% } %>
    </div>

    <div
      class="relative flex flex-col gap-5 border border-helm-cyan/15 p-7 backdrop-blur-md"
      style="background: linear-gradient(180deg, rgba(125, 211, 224, 0.05) 0%, rgba(8, 42, 69, 0.55) 30%, rgba(4, 27, 50, 0.55) 100%);"
    >
      <span aria-hidden class="pointer-events-none absolute right-0 top-0 size-2.5 border-r border-t border-helm-brass/70"></span>
      <span aria-hidden class="pointer-events-none absolute bottom-0 left-0 size-2.5 border-b border-l border-helm-brass/70"></span>

      <div>
        <div class="eyebrow">reconciliation · dollars</div>
        <h3
          class="mt-2 text-[22px] font-bold leading-tight tracking-tight text-helm-vellum"
          style="font-family: var(--font-display); letter-spacing: -0.02em;"
        >
          Money <span class="text-helm-cyan">routed</span>
        </h3>
      </div>

      <div class="grid grid-cols-2 gap-x-4 gap-y-5">
        <% [
          { label: 'ground truth $', value: h.truth_dollars, tone: undefined },
          { label: 'reconciled $', value: h.dollars_reconciled, tone: undefined },
          { label: 'max single drift', value: h.max_payout_drift_usd, tone: h.max_payout_drift_usd <= 0.5 ? 'pass' : h.max_payout_drift_usd <= 2 ? 'warn' : 'fail' },
          { label: 'total drift', value: h.total_payout_drift_usd, tone: h.total_payout_drift_usd <= 5 ? 'pass' : 'warn' }
        ].forEach(dollar => {
          const color = dollar.tone === 'pass' ? 'text-helm-pass' : dollar.tone === 'warn' ? 'text-helm-warn' : dollar.tone === 'fail' ? 'text-helm-fail' : 'text-helm-vellum';
        %>
          <div class="flex flex-col gap-1.5">
            <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-helm-cyan-dim">
              <%= dollar.label %>
            </span>
            <span class="readout text-[24px] leading-none <%= color %>"><%= formatUsd(dollar.value, 2) %></span>
          </div>
        <% }) %>
      </div>

      <div class="hairline"></div>

      <div class="grid grid-cols-2 gap-4">
        <% [
          { label: 'status accuracy', value: h.status_classification.accuracy, suffix: '', digits: 3 },
          { label: 'parse rate', value: h.extraction.parse_rate, suffix: '', digits: 3 }
        ].forEach(dial => {
          const tone = dial.value >= 0.95 ? 'text-helm-pass glow-pass' : dial.value >= 0.85 ? 'text-helm-warn' : 'text-helm-fail';
        %>
          <div class="flex flex-col items-start gap-1.5">
            <span class="font-mono text-[10px] uppercase tracking-[0.18em] text-helm-cyan-dim">
              <%= dial.label %>
            </span>
            <span class="readout text-[24px] leading-none <%= tone %>">
              <%= dial.value.toFixed(dial.digits) %><%= dial.suffix %>
            </span>
          </div>
        <% }) %>
      </div>

      <div class="hairline"></div>
      <div class="font-mono text-[10px] uppercase tracking-[0.18em] text-helm-cyan-dim">
        wall <%= formatMs(h.wall_ms) %> · seed <%= payoutReport.seed %> · extractor{' '}
        <span class="text-helm-vellum"><%= payoutReport.extractor %></span>
      </div>
    </div>
  </section>
</div>
