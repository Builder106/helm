<%
const sizeVal = (typeof size !== 'undefined') ? size : 28;
const classStr = (typeof className !== 'undefined') ? className : '';
const toneVal = (typeof tone !== 'undefined') ? tone : 'brass';
const stroke = toneVal === 'brass' ? 'stroke-helm-brass' : 'stroke-helm-vellum';
const fill = toneVal === 'brass' ? 'fill-helm-brass' : 'fill-helm-vellum';
%>
<svg
  width="<%= sizeVal %>"
  height="<%= sizeVal %>"
  viewBox="0 0 32 32"
  class="<%= classStr %>"
  role="img"
  aria-label="Helm"
>
  <rect width="32" height="32" rx="3" class="fill-helm-bg-2" />
  <g transform="translate(16, 16)">
    <circle cx="0" cy="0" r="10" fill="none" class="<%= stroke %>" stroke-width="1.4" />
    <circle cx="0" cy="0" r="7" fill="none" class="<%= stroke %>" stroke-width="0.8" opacity="0.5" />
    <g class="<%= stroke %>" stroke-width="1.2" stroke-linecap="round">
      <line x1="0" y1="-10" x2="0" y2="10" />
      <line x1="-10" y1="0" x2="10" y2="0" />
      <line x1="-7.07" y1="-7.07" x2="7.07" y2="7.07" opacity="0.55" />
      <line x1="-7.07" y1="7.07" x2="7.07" y2="-7.07" opacity="0.55" />
    </g>
    <circle cx="0" cy="0" r="2.4" class="<%= fill %>" />
    <g class="<%= stroke %>" stroke-width="1.5" stroke-linecap="round">
      <line x1="0" y1="-11.6" x2="0" y2="-13.4" />
      <line x1="0" y1="11.6" x2="0" y2="13.4" />
      <line x1="-11.6" y1="0" x2="-13.4" y2="0" />
      <line x1="11.6" y1="0" x2="13.4" y2="0" />
    </g>
  </g>
</svg>
