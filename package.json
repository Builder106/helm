{
  "name": "helm",
  "version": "0.0.0",
  "private": true,
  "description": "Llama 4 (via Groq) + MCP executive co-pilot for small-and-mid-market business operations. Four back-office workflows, measured per task.",
  "license": "MIT",
  "author": "Yinka Vaughan",
  "repository": {
    "type": "git",
    "url": "https://github.com/Builder106/Helm.git"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./back\" --filter \"./mcp/*\" dev",
    "build": "pnpm --recursive --filter \"./back\" --filter \"./mcp/*\" build",
    "lint": "pnpm --recursive --filter \"./back\" --filter \"./mcp/*\" lint",
    "typecheck": "pnpm --recursive --filter \"./back\" --filter \"./mcp/*\" typecheck && pnpm typecheck:data",
    "typecheck:data": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts --pass-with-no-tests",
    "test:demo": "DEMO=1 playwright test --config=e2e/playwright.demo.config.ts --pass-with-no-tests",
    "data:generate": "tsx --env-file-if-exists=.env data/generators/index.ts",
    "data:render-png": "tsx --env-file-if-exists=.env data/render-png/index.ts",
    "measure": "tsx --env-file-if-exists=.env data/measurements/run-all.ts",
    "measure:invoice-ocr": "tsx --env-file-if-exists=.env data/measurements/invoice-ocr.ts",
    "measure:payout-reconciler": "tsx --env-file-if-exists=.env data/measurements/payout-reconciler.ts"
  },
  "devDependencies": {
    "@google/genai": "^2.12.0",
    "@libsql/client": "^0.17.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "groq-sdk": "^1.3.0",
    "playwright-bdd": "^9.2.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "zod": "^4.4.3"
  }
}
